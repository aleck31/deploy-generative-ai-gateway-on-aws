###############################################################################
# Deployment Configuration
###############################################################################

# --- LiteLLM ---
# Version: https://github.com/berriai/litellm/pkgs/container/litellm/versions?filters%5Bversion_type%5D=tagged
LITELLM_VERSION="main-v1.83.14-stable.patch.3"
BUILD_FROM_SOURCE="false"
# Timezone for budget reset (empty = auto-detect from local machine, e.g. "Asia/Shanghai")
LITELLM_TIMEZONE=""
# Bedrock inference region (empty = use deployment region)
BEDROCK_INFERENCE_REGION=""

# --- UI & API ---
DISABLE_SWAGGER_PAGE="false"
DISABLE_ADMIN_UI="false"

# --- Terraform State ---
TERRAFORM_S3_BUCKET_NAME=""  # Must be globally unique

# --- Network & Access ---
VPC_CIDR_BLOCK="10.31.0.0/16"  # Ignored if EXISTING_VPC_ID is set
EXISTING_VPC_ID=""
PUBLIC_LOAD_BALANCER="true"
ALB_ALLOWED_PREFIX_LIST_ID=""  # Restrict ALB ingress (empty = 0.0.0.0/0)
DISABLE_OUTBOUND_NETWORK_ACCESS="false"
CREATE_VPC_ENDPOINTS_IN_EXISTING_VPC="false"

# --- Distribution (CloudFront / Route53 / Domain) ---
USE_CLOUDFRONT="true"
CLOUDFRONT_PRICE_CLASS="PriceClass_100"
USE_ROUTE53="false"
HOSTED_ZONE_NAME=""
RECORD_NAME=""
CERTIFICATE_ARN=""
CREATE_PRIVATE_HOSTED_ZONE_IN_EXISTING_VPC="false"

# --- Deployment Platform ---
DEPLOYMENT_PLATFORM="ECS"  # ECS or EKS
CPU_ARCHITECTURE=""  # empty = auto-detect, "x86" or "arm"

# --- ECS Compute ---
ECS_VCPUS="2"
ECS_MEMORY_GB="6"
DESIRED_CAPACITY="2"
MIN_CAPACITY="2"
MAX_CAPACITY="4"
ECS_CPU_TARGET_UTILIZATION_PERCENTAGE="50"
ECS_MEMORY_TARGET_UTILIZATION_PERCENTAGE="40"

# --- EKS Compute ---
EXISTING_EKS_CLUSTER_NAME=""
INSTALL_ADD_ONS_IN_EXISTING_EKS_CLUSTER="false"
EKS_ARM_INSTANCE_TYPE="t4g.medium"
EKS_X86_INSTANCE_TYPE="t3.medium"
EKS_ARM_AMI_TYPE="AL2_ARM_64"
EKS_X86_AMI_TYPE="AL2_x86_64"

# --- Database & Cache ---
RDS_INSTANCE_CLASS="db.t4g.medium"
RDS_ALLOCATED_STORAGE_GB="50"
REDIS_NODE_TYPE="cache.t4g.small"
REDIS_NUM_CACHE_CLUSTERS="2"

# --- Auth (Okta) ---
OKTA_ISSUER=""
OKTA_AUDIENCE="api://default"

# --- Observability ---
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_HOST=""
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT=""
LANGSMITH_DEFAULT_RUN_NAME=""

# --- LLM Provider API Keys (placeholder = not configured) ---
OPENAI_API_KEY="placeholder"
AZURE_OPENAI_API_KEY="placeholder"
AZURE_API_KEY="placeholder"
ANTHROPIC_API_KEY="placeholder"
GROQ_API_KEY="placeholder"
COHERE_API_KEY="placeholder"
CO_API_KEY="placeholder"
HF_TOKEN="placeholder"
HUGGINGFACE_API_KEY="placeholder"
DATABRICKS_API_KEY="placeholder"
GEMINI_API_KEY="placeholder"
CODESTRAL_API_KEY="placeholder"
MISTRAL_API_KEY="placeholder"
AZURE_AI_API_KEY="placeholder"
NVIDIA_NIM_API_KEY="placeholder"
XAI_API_KEY="placeholder"
PERPLEXITYAI_API_KEY="placeholder"
GITHUB_API_KEY="placeholder"
DEEPSEEK_API_KEY="placeholder"
AI21_API_KEY="placeholder"

# --- Load Testing (optional) ---
EC2_KEY_PAIR_NAME=""
FAKE_LLM_LOAD_TESTING_ENDPOINT_CERTIFICATE_ARN=""
FAKE_LLM_LOAD_TESTING_ENDPOINT_HOSTED_ZONE_NAME=""
FAKE_LLM_LOAD_TESTING_ENDPOINT_RECORD_NAME=""
